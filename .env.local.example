NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the service_role key so the dashboard can read/write every table.
# NEVER expose this to a public client. This app is server-only (no client-side reads).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin login — single-user auth
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
# Long random string (e.g. `openssl rand -hex 32`). Used to validate session cookies.
SESSION_SECRET=change-me-long-random-string

# ============================================================
# Public ingestion endpoints
# ============================================================

# Shared secret the marketing site (autometa-ai.com) sends in the
# x-ingest-token header when posting to /api/leads/*.
# Generate with `openssl rand -hex 32`. Also set it on the website's
# env so both sides match.
INGEST_TOKEN=change-me-long-random-string

# Secret from Cal.com webhook settings — signs incoming /api/webhooks/cal
# requests with HMAC-SHA256. Cal.com → Settings → Developer → Webhooks →
# "Add webhook" → secret field.
CAL_WEBHOOK_SECRET=change-me-long-random-string
